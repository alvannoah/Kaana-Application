<Page
    x:Class="Frontend.Views.MilkLoading"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
        <local:StringToDecimalConverter x:Key="DecimalConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="420">

        <SplitView.Pane>
            <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">

                        <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"/>

                        <DatePicker Header="Loading Date"
                                    HorizontalAlignment="Stretch"
                                    Date="{Binding FormModel.Date, Mode=TwoWay}"/>

                        <ComboBox Header="Milk Buyer"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding MilkBuyers}"
                                  SelectedValue="{Binding FormModel.MilkBuyerId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name" />

                        <TextBox Header="Vehicle Plate Number"
                                 PlaceholderText="e.g., KBX 123A"
                                 Text="{Binding FormModel.VehicleNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="Receiver Name"
                                 PlaceholderText="e.g., John Doe"
                                 Text="{Binding FormModel.ReceiverName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="Litres Loaded"
                                 InputScope="Number"
                                 Text="{Binding FormModel.LitresLoaded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalConverter}}" />

                        <TextBox Header="Price Per Litre"
                                 InputScope="CurrencyAmount"
                                 Text="{Binding FormModel.PricePerLitre, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalConverter}}" />

                        <TextBox Header="Collected Litres"
                                 InputScope="Number"
                                 Text="{Binding FormModel.CollectedLitres, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalConverter}}" />

                        <Grid Margin="0,4,0,4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel>
                                <TextBlock Text="Total Amount" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{Binding FormModel.Amount}" FontSize="18" FontWeight="Bold" Foreground="#4CAF50"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Variance" FontSize="11" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
                                <TextBlock Text="{Binding FormModel.Variance}" FontSize="18" FontWeight="Bold" Foreground="#F44336"/>
                            </StackPanel>
                        </Grid>

                        <Button Content="Save Dispatch Log"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                Command="{Binding SaveCommand}" />

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Milk Dispatch &amp; Loading Logs"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Content="+ Record Milk Loading"
                            HorizontalAlignment="Right"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.8*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.4*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Date" FontWeight="SemiBold"/>
                    <TextBlock Text="Buyer" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Vehicle" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Loaded" Grid.Column="3" FontWeight="SemiBold"/>
                    <TextBlock Text="Collected" Grid.Column="4" FontWeight="SemiBold"/>
                    <TextBlock Text="Variance" Grid.Column="5" FontWeight="SemiBold"/>
                    <TextBlock Text="Amount" Grid.Column="6" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="7" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding MilkLoadings}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MilkLoading">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.8*"/>
                                    <ColumnDefinition Width="1.2*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.1*"/>
                                    <ColumnDefinition Width="1.4*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind local:MilkLoading.FormatShortDate(Date)}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind MilkBuyer.Name}" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind VehicleNumber}" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind LitresLoaded}" Grid.Column="3" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind CollectedLitres}" Grid.Column="4" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Variance}" Grid.Column="5" VerticalAlignment="Center" Foreground="#F44336" FontWeight="SemiBold"/>
                                <TextBlock Text="{x:Bind Amount}" Grid.Column="6" VerticalAlignment="Center" FontWeight="Bold" Foreground="#4CAF50"/>

                                <StackPanel Grid.Column="7" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>