<Page
    x:Class="Frontend.Views.AdvancePayments"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
        <local:StringToDecimalConverter x:Key="NumericConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="420">

        <SplitView.Pane>
            <Grid Padding="20" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">

                        <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"/>

                        <ComboBox Header="Select Farmer"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding Farmers}"
                                  SelectedValue="{Binding FormModel.FarmerId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="FirstName" />

                        <TextBox Header="Advance Amount"
                                 InputScope="CurrencyAmount"
                                 Text="{Binding FormModel.Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericConverter}}"/>

                        <TextBox Header="Repaid Amount"
                                 InputScope="CurrencyAmount"
                                 Text="{Binding FormModel.RepaidAmount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource NumericConverter}}"/>

                        <TextBox Header="Notes"
                                 AcceptsReturn="True"
                                 Height="80"
                                 Text="{Binding FormModel.Notes, Mode=TwoWay}"/>

                        <DatePicker Header="Date Issued"
                                    HorizontalAlignment="Stretch"
                                    Date="{Binding FormModel.DateIssued, Mode=TwoWay}"/>

                        <Button Content="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                                Command="{Binding SaveCommand}"
                                HorizontalAlignment="Stretch"
                                Background="#4CAF50"
                                Foreground="White"
                                Height="40"/>

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <StackPanel>
                        <TextBlock Text="Farmer Advances" FontSize="22" FontWeight="Bold"/>
                        <TextBlock Text="Manage farmer loans and repayment tracking." FontSize="12" Foreground="Gray"/>
                    </StackPanel>

                    <Button Content="+ New Advance"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Bottom"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Farmer Name" FontWeight="SemiBold"/>
                    <TextBlock Text="Amount" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Repaid" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Balance" Grid.Column="3" FontWeight="SemiBold"/>
                    <TextBlock Text="Date" Grid.Column="4" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="5" FontWeight="SemiBold" HorizontalAlignment="Right"/>
                </Grid>

                <ListView ItemsSource="{Binding Advances}"
                          SelectedItem="{Binding SelectedAdvance, Mode=TwoWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Advance">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind Farmer.FirstName}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind Farmer.LastName}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{x:Bind Amount}" Grid.Column="1" VerticalAlignment="Center"/>

                                <TextBlock Text="{x:Bind RepaidAmount}" Grid.Column="2" Foreground="#F44336" VerticalAlignment="Center"/>

                                <TextBlock Text="{x:Bind Balance}" Grid.Column="3" FontWeight="Bold" Foreground="#4CAF50" VerticalAlignment="Center"/>

                                <TextBlock Text="{x:Bind DateIssued}" Grid.Column="4" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="5" 
                                            Orientation="Horizontal"
                                            HorizontalAlignment="Right" 
                                            Spacing="6" 
                                            VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>