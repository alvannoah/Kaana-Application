<Page
    x:Class="Frontend.Views.DashBoard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:Core.DTOs"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <ScrollViewer>
        <StackPanel Padding="24" Spacing="24">
            
            <StackPanel>
                <TextBlock Text="Management Dashboard"
                           FontSize="28"
                           FontWeight="Bold"/>
                <TextBlock Text="Milk Collection System Overview"
                           Foreground="Gray"
                           Margin="0,4,0,0"/>
            </StackPanel>

            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="TOTAL REGISTERED FARMERS" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalFarmers}" FontSize="28" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="TOTAL MILK COLLECTED" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                            <TextBlock Text="{Binding TotalMilkCollected}" FontSize="28" FontWeight="Bold"/>
                            <TextBlock Text=" Ltrs" FontSize="16" Foreground="Gray" VerticalAlignment="Bottom" Margin="4,0,0,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Grid.Column="2" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="TOTAL REVENUE" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalRevenue}" FontSize="28" FontWeight="Bold" Foreground="#2E7D32" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="OPERATIONAL EXPENSES" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Text="{Binding TotalExpenses}" FontSize="24" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="NET PROFIT" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Text="{Binding NetProfit}" FontSize="24" FontWeight="Bold" Foreground="#4CAF50" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
                <Border Grid.Column="2" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="OUTSTANDING ADVANCES" FontSize="11" FontWeight="SemiBold" Foreground="Gray"/>
                        <TextBlock Text="{Binding OutstandingAdvances}" FontSize="24" FontWeight="Bold" Foreground="#F57C00" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>
            </Grid>

            <Border Padding="20" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                <StackPanel Spacing="16">
                    <TextBlock Text="Current Collection Period" FontSize="16" FontWeight="Bold"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Period Name" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding CurrentPeriodName}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="1">
                            <TextBlock Text="Active Farmers This Period" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding ActiveFarmersThisPeriod}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Status" FontSize="12" Foreground="Gray"/>
                            <TextBlock Text="{Binding IsPeriodClosed}" FontSize="16" FontWeight="SemiBold" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>
            
            <Grid ColumnSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <Border Grid.Column="0" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Top Farmers (Current Period)" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ListView ItemsSource="{Binding TopFarmers}" MaxHeight="300" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="dtos:TopFarmerDto">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind FarmerName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        
                                        <TextBlock Grid.Column="1" Text="{x:Bind TotalLitres}" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
                
                <Border Grid.Column="1" Padding="16" CornerRadius="8" BorderThickness="1" BorderBrush="#E0E0E0">
                    <StackPanel>
                        <TextBlock Text="Outstanding Advances Breakdown" FontSize="16" FontWeight="Bold" Margin="0,0,0,12"/>
                        <ListView ItemsSource="{Binding OutstandingAdvancesList}" MaxHeight="300" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="dtos:OutstandingAdvanceDto">
                                    <Grid Padding="0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind FarmerName}" TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="1" Text="{x:Bind OutstandingBalance}" Foreground="#F57C00" FontWeight="Bold" VerticalAlignment="Center" Margin="12,0,0,0"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</Page>