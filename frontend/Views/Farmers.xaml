<Page
    x:Class="Frontend.Views.Farmers"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml" 
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="400">

        <SplitView.Pane>
            <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="15">

                        <TextBlock
                            Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                            FontSize="18"
                            FontWeight="Bold"
                            Foreground="#4CAF50"/>

                        <Grid ColumnSpacing="10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBox Header="First Name"
                                     Text="{Binding FormModel.FirstName, Mode=TwoWay}"/>

                            <TextBox Header="Last Name"
                                     Grid.Column="1"
                                     Text="{Binding FormModel.LastName, Mode=TwoWay}"/>
                        </Grid>

                        <TextBox Header="Email"
                                 InputScope="EmailNameOrAddress"
                                 Text="{Binding FormModel.Email, Mode=TwoWay}"/>

                        <TextBox Header="Primary Phone"
                                 InputScope="TelephoneNumber"
                                 Text="{Binding FormModel.PrimaryPhone, Mode=TwoWay}"/>

                        <TextBox Header="Secondary Phone"
                                 InputScope="TelephoneNumber"
                                 Text="{Binding FormModel.SecondaryPhone, Mode=TwoWay}"/>

                        <ComboBox Header="Collection Center"
                                  HorizontalAlignment="Stretch"
                                  ItemsSource="{Binding CollectionCenters}"
                                  SelectedValue="{Binding FormModel.CollectionCenterId, Mode=TwoWay}"
                                  SelectedValuePath="Id"
                                  DisplayMemberPath="Name" />

                        <Button Content="Save Farmer"
                                HorizontalAlignment="Stretch"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                Command="{Binding SaveCommand}" />

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Farmers"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Content="+ Add New Farmer"
                            HorizontalAlignment="Right"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Name" FontWeight="SemiBold"/>
                    <TextBlock Text="Primary Phone" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Collection Center" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="3" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding Farmers}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Farmer">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>

                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <TextBlock Text="{x:Bind FirstName}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind LastName}" VerticalAlignment="Center"/>
                                </StackPanel>

                                <TextBlock Text="{x:Bind PrimaryPhone}" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind CollectionCenter.Name}" Grid.Column="2" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="5">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>