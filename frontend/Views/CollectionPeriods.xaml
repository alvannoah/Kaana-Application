<Page
    x:Class="Frontend.Views.CollectionPeriods"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToStatusColorConverter x:Key="StatusColorConverter"/>
        <local:BoolToStatusTextConverter x:Key="StatusTextConverter"/>
        <local:NullToVisibilityConverter x:Key="NullToVisibilityConverter"/>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="15-Day Collection Periods Management"
                       FontSize="22"
                       FontWeight="Bold"/>
            <TextBlock Text="Select an open cycle sprint below to review, finalize calculations, and close out accounting logs."
                       FontSize="12"
                       Foreground="Gray"
                       Margin="0,4,0,0"/>
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <StackPanel Spacing="10">
                <Grid Background="#F5F5F5" Padding="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Period Window Name" FontWeight="SemiBold"/>
                    <TextBlock Text="Start Date" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="End Date" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Status" Grid.Column="3" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding CollectionPeriods}"
                          SelectedItem="{Binding SelectedCollectionPeriod, Mode=TwoWay}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0,2"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CollectionPeriod">
                            <Grid Padding="12" Background="Transparent">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind Name}" FontWeight="Medium" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind local:CollectionPeriods.FormatShortDate(StartDate)}" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind local:CollectionPeriods.FormatShortDate(EndDate)}" Grid.Column="2" VerticalAlignment="Center"/>

                                <Border Grid.Column="3" 
                                        HorizontalAlignment="Left" 
                                        Padding="8,4" 
                                        CornerRadius="12"
                                        Background="{x:Bind IsClosed, Converter={StaticResource StatusColorConverter}, ConverterParameter='Bg'}">
                                    <TextBlock Text="{x:Bind IsClosed, Converter={StaticResource StatusTextConverter}}" 
                                               FontSize="11" 
                                               FontWeight="Bold"
                                               Foreground="{x:Bind IsClosed, Converter={StaticResource StatusColorConverter}, ConverterParameter='Fg'}"/>
                                </Border>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </StackPanel>

            <Border Grid.Column="1" 
                    Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" 
                    BorderBrush="#DDD" 
                    BorderThickness="1" 
                    CornerRadius="6" 
                    Padding="20"
                    VerticalAlignment="Top">

                <Grid>
                    <StackPanel Spacing="10" 
                                Visibility="{Binding SelectedCollectionPeriod, Converter={StaticResource NullToVisibilityConverter}, ConverterParameter='Invert'}">
                        <TextBlock Text="No Period Selected" 
                                   HorizontalAlignment="Center" 
                                   Foreground="Gray" 
                                   Margin="0,40"
                                   FontStyle="Italic"/>
                    </StackPanel>

                    <StackPanel Spacing="16" 
                                Visibility="{Binding SelectedCollectionPeriod, Converter={StaticResource NullToVisibilityConverter}}">

                        <TextBlock Text="Cycle Operational Details" FontSize="16" FontWeight="Bold" Foreground="#4CAF50"/>
                        <MenuFlyoutSeparator/>

                        <StackPanel>
                            <TextBlock Text="Target Period Name" FontSize="11" Foreground="Gray"/>
                            <TextBlock Text="{Binding SelectedCollectionPeriod.Name}" FontSize="18" FontWeight="Bold"/>
                        </StackPanel>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="1*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="Opening Date" FontSize="11" Foreground="Gray"/>
                                <TextBlock Text="{x:Bind local:CollectionPeriods.FormatShortDate(ViewModel.SelectedCollectionPeriod.StartDate), Mode=OneWay}" FontWeight="SemiBold"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Closing Date" FontSize="11" Foreground="Gray"/>

                                <TextBlock Text="{x:Bind local:CollectionPeriods.FormatShortDate(ViewModel.SelectedCollectionPeriod.EndDate), Mode=OneWay}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Grid>

                        <Border Background="#FFF8E1" BorderBrush="#FFE082" BorderThickness="1" Padding="12" CornerRadius="4"
                                Visibility="{Binding SelectedCollectionPeriod.IsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='Invert'}">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <SymbolIcon Symbol="Import" Foreground="#FFA000"/>
                                <TextBlock Text="Warning: Closing this cycle locks current farmer deliveries and processes reports. This action cannot be undone." 
                                           TextWrapping="WrapWholeWords" 
                                           FontSize="12" 
                                           Foreground="#5D4037"
                                           Width="260"/>
                            </StackPanel>
                        </Border>

                        <Button Content="Close Period and Generate Reports"
                                HorizontalAlignment="Stretch"
                                Height="44"
                                FontSize="14"
                                FontWeight="Bold"
                                Background="#F44336"
                                Foreground="White"
                                Command="{Binding ClosePeriodCommand}"
                                Visibility="{Binding SelectedCollectionPeriod.IsClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter='Invert'}"/>

                        <Border Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" Padding="12" CornerRadius="4"
                                Visibility="{Binding SelectedCollectionPeriod.IsClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                <SymbolIcon Symbol="Accept" Foreground="#388E3C"/>
                                <TextBlock Text="This historical sprint ledger is completely locked and processed." 
                                           FontWeight="Medium" 
                                           Foreground="#2E7D32" 
                                           FontSize="12" 
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>