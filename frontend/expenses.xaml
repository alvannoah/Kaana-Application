<Page
    x:Class="Frontend.expenses"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Frontend"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid Background="#ede8b4">
            <NavigationView 
              PaneDisplayMode="LeftCompact"
              IsBackButtonVisible="Visible"
              IsSettingsVisible="False"
              CompactPaneLength="48"
              OpenPaneLength="256">

                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" Tapped="NavigationViewItem_Tapped"/>
                    <NavigationViewItem Content="farmers payment" Tag="livestock" Icon="People" Tapped="NavigationViewItem_Tapped_2"/>
                    <NavigationViewItem Content="expenses" Tag="expeses" Icon="Shop" Tapped="NavigationViewItem_Tapped_3" IsSelected="True"/>
                    <NavigationViewItem Content="transport" Tag="transport" Icon="Directions" Tapped="NavigationViewItem_Tapped_4"/>
                    <NavigationViewItem Content="collections" Tag="collects" Icon="Library" Tapped="NavigationViewItem_Tapped_5"/>
                    <NavigationViewItem Content="advances" Tag="advances" Icon="Calculator" Tapped="NavigationViewItem_Tapped"/>
                </NavigationView.MenuItems>
            </NavigationView>

            <!-- ScrollViewer for main content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,0">

                <Grid>
                    <!-- Main Title -->
                    <TextBlock Text="Farm Expenses - Cloud Pastoral"
                           FontWeight="Bold" 
                           FontSize="28"
                           VerticalAlignment="Top" 
                           Margin="280,10,0,0" />

                    <!-- DairyFlow Subtitle -->
                    <TextBlock Text="DAIryFlow"
                           FontWeight="SemiBold"
                           FontSize="16"
                           Foreground="#666"
                           VerticalAlignment="Top"
                           Margin="280,45,0,0" />

                    <TextBlock Text="MANAGEMENT • Operational Hub"
                           FontSize="12"
                           Foreground="#888"
                           VerticalAlignment="Top"
                           Margin="280,68,0,0" />

                    <!-- Search Box -->
                    <TextBox PlaceholderText="Search expenses..."
                        FontSize="14"
                        CornerRadius="10"
                        Background="White"
                        Width="200"
                        Margin="864,10,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"/>

                    <Button Content="+ Add Expense"
                        FontSize="14"
                        Background="#2E7D32"
                        CornerRadius="10"
                        Foreground="White"
                        Width="140"
                        Margin="1080,10,0,0"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Top"/>

                    <!-- Log New Expense Card -->
                    <Border Background="White" 
                        CornerRadius="12"
                        Margin="280,110,50,0"
                        Height="480"
                        VerticalAlignment="Top">
                        <StackPanel Margin="20">
                            <TextBlock Text="Log New Expense"
                                   FontWeight="Bold"
                                   FontSize="20"
                                   Margin="0,0,0,8"/>

                            <TextBlock Text="Keep your dairy operations balanced by recording operational outflows."
                                   FontSize="12"
                                   Foreground="#666"
                                   Margin="0,0,0,25"/>

                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Date Field -->
                                <TextBlock Text="Date"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#2E7D32"
                                       Grid.Row="0"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                                <DatePicker Grid.Row="0"
                                        Grid.Column="1"
                                        Width="322"
                                        Margin="0,0,0,10"/>

                                <!-- Description Field -->
                                <TextBlock Text="Description"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#2E7D32"
                                       Grid.Row="1"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                                <TextBox PlaceholderText="Enter description..."
                                     Grid.Row="1"
                                     Grid.Column="1"
                                     CornerRadius="8"
                                     Height="40"
                                     Margin="0,0,0,10"/>

                                <!-- Item Field -->
                                <TextBlock Text="Item"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#2E7D32"
                                       Grid.Row="2"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                                <TextBox PlaceholderText="Enter item name"
                                     Grid.Row="2"
                                     Grid.Column="1"
                                     CornerRadius="8"
                                     Height="40"
                                     Margin="0,0,0,10"/>

                                <!-- Quantity Field -->
                                <TextBlock Text="Quantity"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#2E7D32"
                                       Grid.Row="3"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBox PlaceholderText="0"
                                         CornerRadius="8"
                                         Height="40"
                                         Grid.Column="0"
                                         Width="120"
                                         TextAlignment="Center"/>
                                    <TextBlock Text="units"
                                           Grid.Column="1"
                                           VerticalAlignment="Center"
                                           Foreground="#666"
                                           Margin="10,0,0,0"/>
                                </Grid>

                                <!-- Amount Field -->
                                <TextBlock Text="Amount"
                                       FontWeight="SemiBold"
                                       FontSize="13"
                                       Foreground="#2E7D32"
                                       Grid.Row="4"
                                       Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Margin="0,0,10,10"/>
                                <TextBox Text="$ 0.00"
                                     Grid.Row="4"
                                     Grid.Column="1"
                                     FontSize="16"
                                     FontWeight="SemiBold"
                                     CornerRadius="8"
                                     Height="40"
                                     Margin="0,0,0,10"/>

                                <!-- Buttons -->
                                <StackPanel Grid.Row="5"
                                        Grid.Column="1"
                                        Orientation="Horizontal" 
                                        Margin="0,20,0,0" 
                                        HorizontalAlignment="Right">
                                    <Button Content="Clear Form"
                                        Background="#f5f5f5"
                                        CornerRadius="8"
                                        Width="100"
                                        Height="35"
                                        Margin="0,0,10,0"/>
                                    <Button Content="Save Expense"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        CornerRadius="8"
                                        Width="120"
                                        Height="35"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Recent Ledger Activity Card -->
                    <Border Background="White" 
                        CornerRadius="12"
                        Margin="280,605,50,50"
                        VerticalAlignment="Top">
                        <StackPanel Margin="20">
                            <TextBlock Text="Recent Ledger Activity"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Foreground="#2E7D32"
                                   Margin="0,0,0,15"/>

                            <!-- Table Header -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="DATE" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"/>
                                <TextBlock Text="DESCRIPTION" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"
                                       Grid.Column="1"/>
                                <TextBlock Text="ITEM" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"
                                       Grid.Column="2"/>
                                <TextBlock Text="QTY" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="AMOUNT" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="STATUS" 
                                       FontWeight="Bold" 
                                       Foreground="#666" 
                                       FontSize="11"
                                       Grid.Column="5"/>
                            </Grid>

                            <Border Height="1" Background="#E0E0E0" Margin="0,0,0,12"/>

                            <!-- Row 1 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 24, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Feed purchase for dairy herd" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Dairy Feed" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="50" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$1,240.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processed" 
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 2 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 23, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Milking machine repair" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Spare parts" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="3" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$450.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processed" 
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 3 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 22, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Veterinary consultation" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Health Check" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="1" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$820.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processing" 
                                       FontSize="12" 
                                       Foreground="#FF9800" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 4 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 21, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Fuel for milk transport" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Diesel" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="50 L" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$100.50" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processing" 
                                       FontSize="12" 
                                       Foreground="#FF9800" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 5 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 20, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Cleaning supplies" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Detergents" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="10" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$75.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processed" 
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 6 - Additional row for scroll -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 19, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Farm equipment rental" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Tractor" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="8 hrs" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$320.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processed" 
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 7 -->
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 18, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Electricity bill" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Utilities" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="1" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$245.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processing" 
                                       FontSize="12" 
                                       Foreground="#FF9800" 
                                       Grid.Column="5"/>
                            </Grid>

                            <!-- Row 8 -->
                            <Grid Margin="0,0,0,15">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="200"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 17, 2025" 
                                       FontSize="12" 
                                       Grid.Column="0"/>
                                <TextBlock Text="Water system maintenance" 
                                       FontSize="12" 
                                       Grid.Column="1"/>
                                <TextBlock Text="Plumbing" 
                                       FontSize="12" 
                                       Grid.Column="2"/>
                                <TextBlock Text="1" 
                                       FontSize="12" 
                                       Grid.Column="3"
                                       TextAlignment="Center"/>
                                <TextBlock Text="$180.00" 
                                       FontSize="12" 
                                       FontWeight="SemiBold"
                                       Grid.Column="4"
                                       TextAlignment="Right"/>
                                <TextBlock Text="• Processed" 
                                       FontSize="12" 
                                       Foreground="#4CAF50" 
                                       Grid.Column="5"/>
                            </Grid>

                            <Border Height="1" Background="#E0E0E0"/>

                            <Grid Margin="0,10,0,0">
                                <TextBlock Text="Showing 8 of 32 entries"
                                       FontSize="11"
                                       Foreground="#888"
                                       HorizontalAlignment="Left"/>
                                <Button Content="View All Transactions"
                                    Background="Transparent"
                                    Foreground="#2E7D32"
                                    BorderThickness="0"
                                    FontSize="12"
                                    HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>

</Page>
