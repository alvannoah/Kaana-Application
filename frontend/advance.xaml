<Page
    x:Class="Frontend.advance"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:Frontend"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid Background="#ede8b4">
            <NavigationView 
            PaneDisplayMode="LeftCompact"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            CompactPaneLength="48"
            OpenPaneLength="256">

                <NavigationView.MenuItems>
                    <NavigationViewItem Content="Dashboard" Tag="dashboard" Icon="Home" Tapped="NavigationViewItem_Tapped_6"/>
                    <NavigationViewItem Content="Farmers Payment" Tag="livestock" Icon="People" Tapped="NavigationViewItem_Tapped"/>
                    <NavigationViewItem Content="Expenses" Tag="expenses" Icon="Shop" Tapped="NavigationViewItem_Tapped_1"/>
                    <NavigationViewItem Content="Transport" Tag="transport" Icon="Directions" Tapped="NavigationViewItem_Tapped_2"/>
                    <NavigationViewItem Content="Collections" Tag="collections" Icon="Library" Tapped="NavigationViewItem_Tapped_3"/>
                    <NavigationViewItem Content="Advances" Tag="advances" Icon="Calculator" IsSelected="True" Tapped="NavigationViewItem_Tapped_4"/>
                </NavigationView.MenuItems>
            </NavigationView>

            <!-- ScrollViewer for main content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Margin="0,0,0,0">

                <StackPanel Margin="280,10,50,50">

                    <!-- Header Section -->
                    <StackPanel Margin="0,0,0,20">
                        <TextBlock Text="Advance Loans - Cloud Pastoral"
                               FontWeight="Bold" 
                               FontSize="28"/>
                        <TextBlock Text="DAIryFlow"
                               FontWeight="SemiBold"
                               FontSize="16"
                               Foreground="#666"
                               Margin="0,5,0,0"/>
                        <TextBlock Text="FINANCIAL MANAGEMENT • Operational Hub"
                               FontSize="12"
                               Foreground="#888"
                               Margin="0,2,0,0"/>
                    </StackPanel>

                    <!-- Search and Add Button Row -->
                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Search advances..."
                             FontSize="14"
                             CornerRadius="10"
                             Background="White"
                             Width="250"
                             Grid.Column="0"
                             HorizontalAlignment="Left"
                             Padding="10,8"/>
                        <Button Content="+ New Advance"
                            FontSize="14"
                            Background="#2E7D32"
                            CornerRadius="10"
                            Foreground="White"
                            Width="140"
                            Height="36"
                            Grid.Column="1"
                            HorizontalAlignment="Right"/>
                    </Grid>

                    <!-- Stats Cards Row -->
                    <Border Background="White" 
                        CornerRadius="12"
                        Margin="0,0,0,20">
                        <Grid Margin="25" Height="90">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <!-- Total Outstanding -->
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="TOTAL OUTSTANDING"
                                       FontSize="10"
                                       Foreground="#888"
                                     />
                                <TextBlock Text="$45,250.00"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#D32F2F"/>
                                <TextBlock Text="Across 28 farmers"
                                       FontSize="10"
                                       Foreground="#666"/>
                            </StackPanel>

                            <Border Grid.Column="1" Width="1" Background="#E0E0E0" Margin="20,0"/>

                            <!-- This Month Disbursed -->
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="THIS MONTH DISBURSED"
                                       FontSize="10"
                                       Foreground="#888"
                                       />
                                <TextBlock Text="$12,500.00"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#2196F3"/>
                                <TextBlock Text="▲ 15% vs last month"
                                       FontSize="10"
                                       Foreground="#4CAF50"/>
                            </StackPanel>

                            <Border Grid.Column="3" Width="1" Background="#E0E0E0" Margin="20,0"/>

                            <!-- Repayment Rate -->
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="REPAYMENT RATE"
                                       FontSize="10"
                                       Foreground="#888"
                                       />
                                <TextBlock Text="87%"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#4CAF50"/>
                                <TextBlock Text="On-time payments"
                                       FontSize="10"
                                       Foreground="#4CAF50"/>
                            </StackPanel>

                            <Border Grid.Column="5" Width="1" Background="#E0E0E0" Margin="20,0"/>

                            <!-- Active Loans -->
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="ACTIVE LOANS"
                                       FontSize="10"
                                       Foreground="#888"
                                       />
                                <TextBlock Text="32"
                                       FontSize="24"
                                       FontWeight="Bold"
                                       Foreground="#2E7D32"/>
                                <TextBlock Text="4 overdue"
                                       FontSize="10"
                                       Foreground="#FF9800"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Two Column Layout for Form and Sidebar -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="300"/>
                        </Grid.ColumnDefinitions>

                        <!-- Left Column - New Advance Request Form -->
                        <Border Background="White" 
                            CornerRadius="12"
                            Margin="0,0,20,20"
                            Grid.Column="0">
                            <StackPanel Margin="25">
                                <TextBlock Text="New Advance Request"
                                       FontWeight="Bold"
                                       FontSize="20"
                                       Margin="0,0,0,10"/>

                                <TextBlock Text="Issue advances to farmers for operational needs"
                                       FontSize="12"
                                       Foreground="#666"
                                       Margin="0,0,0,25"/>

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                        <RowDefinition Height="Auto"/>
                                    </Grid.RowDefinitions>

                                    <!-- Farmer Selection -->
                                    <TextBlock Text="Select Farmer"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="0"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <ComboBox PlaceholderText="Search or select farmer"
                                          Grid.Row="0"
                                          Grid.Column="1"
                                          CornerRadius="8"
                                          Height="40"
                                          Margin="0,0,0,10">
                                        <ComboBoxItem Content="Amara Okafor - FRM-2024-001"/>
                                        <ComboBoxItem Content="John Kiplagat - FRM-2024-002"/>
                                        <ComboBoxItem Content="Sofia Martinez - FRM-2024-003"/>
                                        <ComboBoxItem Content="Lukas Schmidt - FRM-2024-004"/>
                                    </ComboBox>

                                    <!-- Loan Amount -->
                                    <TextBlock Text="Loan Amount (USD)"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="1"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <TextBox PlaceholderText="$ 0.00"
                                         Grid.Row="1"
                                         Grid.Column="1"
                                         CornerRadius="8"
                                         Height="40"
                                         Margin="0,0,0,10"
                                         Padding="10,0"/>

                                    <!-- Interest Rate -->
                                    <TextBlock Text="Interest Rate (%)"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="2"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <TextBox Text="5.0"
                                         Grid.Row="2"
                                         Grid.Column="1"
                                         CornerRadius="8"
                                         Height="40"
                                         Width="120"
                                         Margin="0,0,0,10"
                                         HorizontalAlignment="Left"
                                         Padding="10,0"/>

                                    <!-- Repayment Period -->
                                    <TextBlock Text="Repayment Period"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="3"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <ComboBox Grid.Row="3"
                                          Grid.Column="1"
                                          Width="150"
                                          CornerRadius="8"
                                          Height="40"
                                          Margin="0,0,0,10"
                                          HorizontalAlignment="Left"
                                          SelectedIndex="0">
                                        <ComboBoxItem Content="3 months"/>
                                        <ComboBoxItem Content="6 months"/>
                                        <ComboBoxItem Content="12 months"/>
                                        <ComboBoxItem Content="24 months"/>
                                    </ComboBox>

                                    <!-- Purpose -->
                                    <TextBlock Text="Purpose"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="4"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <ComboBox Grid.Row="4"
                                          Grid.Column="1"
                                          CornerRadius="8"
                                          Height="40"
                                          Margin="0,0,0,10">
                                        <ComboBoxItem Content="Farm Equipment"/>
                                        <ComboBoxItem Content="Feed Purchase"/>
                                        <ComboBoxItem Content="Veterinary Services"/>
                                        <ComboBoxItem Content="Farm Expansion"/>
                                        <ComboBoxItem Content="Emergency"/>
                                    </ComboBox>

                                    <!-- Disbursement Date -->
                                    <TextBlock Text="Disbursement Date"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Foreground="#2E7D32"
                                           Grid.Row="5"
                                           Grid.Column="0"
                                           VerticalAlignment="Center"
                                           Margin="0,0,10,10"/>
                                    <DatePicker Grid.Row="5"
                                            Grid.Column="1"
                                            Width="250"
                                            VerticalAlignment="Top"
                                            Margin="0,0,0,10"/>

                                    <!-- Buttons -->
                                    <StackPanel Grid.Row="6"
                                            Grid.Column="1"
                                            Orientation="Horizontal"
                                            Margin="0,15,0,0"
                                            Spacing="10">
                                        <Button Content="Clear Form"
                                            Background="#f5f5f5"
                                            CornerRadius="8"
                                            Width="100"
                                            Height="38"
                                            Foreground="#555"/>
                                        <Button Content="Issue Advance"
                                            Background="#2E7D32"
                                            Foreground="White"
                                            CornerRadius="8"
                                            Width="120"
                                            Height="38"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Right Column - Quick Actions -->
                        <StackPanel Grid.Column="1" Spacing="15">

                            <!-- Repayment Calculator Card -->
                            <Border Background="White" 
                                CornerRadius="12"
                                Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Repayment Calculator"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="#2E7D32"
                                           Margin="0,0,0,12"/>
                                    <TextBlock Text="Loan Amount"
                                           FontSize="11"
                                           Foreground="#666"
                                           Margin="0,5,0,5"/>
                                    <TextBox PlaceholderText="$"
                                         CornerRadius="8"
                                         Height="38"
                                         Margin="0,0,0,12"
                                         Padding="10,0"/>
                                    <TextBlock Text="Interest Rate (%)"
                                           FontSize="11"
                                           Foreground="#666"
                                           Margin="0,5,0,5"/>
                                    <TextBox Text="5.0"
                                         CornerRadius="8"
                                         Height="38"
                                         Margin="0,0,0,12"
                                         Padding="10,0"/>
                                    <TextBlock Text="Months"
                                           FontSize="11"
                                           Foreground="#666"
                                           Margin="0,5,0,5"/>
                                    <TextBox Text="12"
                                         CornerRadius="8"
                                         Height="38"
                                         Margin="0,0,0,12"
                                         Padding="10,0"/>
                                    <Border Background="#E8F5E9" 
                                        CornerRadius="8" 
                                        Padding="12"
                                        Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="Monthly Payment"
                                                   FontSize="10"
                                                   Foreground="#888"/>
                                            <TextBlock Text="$ 428.00"
                                                   FontSize="22"
                                                   FontWeight="Bold"
                                                   Foreground="#2E7D32"/>
                                            <TextBlock Text="Total Interest: $136.00"
                                                   FontSize="10"
                                                   Foreground="#666"/>
                                        </StackPanel>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <!-- Summary Card -->
                            <Border Background="White" 
                                CornerRadius="12"
                                Padding="18">
                                <StackPanel>
                                    <TextBlock Text="Collections Summary"
                                           FontWeight="Bold"
                                           FontSize="15"
                                           Foreground="#2E7D32"
                                           Margin="0,0,0,12"/>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Due This Week" FontSize="12" Foreground="#666"/>
                                        <TextBlock Text="$4,200" FontSize="13" FontWeight="SemiBold" Foreground="#FF9800" Grid.Column="1"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Due This Month" FontSize="12" Foreground="#666"/>
                                        <TextBlock Text="$15,800" FontSize="13" FontWeight="SemiBold" Foreground="#2196F3" Grid.Column="1"/>
                                    </Grid>
                                    <Grid Margin="0,8,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Overdue" FontSize="12" Foreground="#666"/>
                                        <TextBlock Text="$3,200" FontSize="13" FontWeight="SemiBold" Foreground="#F44336" Grid.Column="1"/>
                                    </Grid>
                                    <Button Content="Process Repayment"
                                        Background="#2E7D32"
                                        Foreground="White"
                                        CornerRadius="8"
                                        Height="38"
                                        FontSize="13"
                                        Margin="0,5,0,0"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Grid>

                    <!-- Recent Advances Ledger -->
                    <Border Background="White" 
                        CornerRadius="12"
                        Margin="0,20,0,0">
                        <StackPanel Margin="25">
                            <TextBlock Text="Recent Advances &amp; Repayments"
                                   FontWeight="SemiBold"
                                   FontSize="16"
                                   Foreground="#2E7D32"
                                   Margin="0,0,0,20"/>

                            <!-- Table Header -->
                            <Border Background="#F5F5F5" 
                                CornerRadius="8" 
                                Padding="10,8"
                                Margin="0,0,0,10">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="140"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="100"/>
                                        <ColumnDefinition Width="120"/>
                                        <ColumnDefinition Width="90"/>
                                        <ColumnDefinition Width="60"/>
                                    </Grid.ColumnDefinitions>

                                    <TextBlock Text="DATE" FontWeight="Bold" Foreground="#555" FontSize="12"/>
                                    <TextBlock Text="FARMER" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="1"/>
                                    <TextBlock Text="AMOUNT" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="2" TextAlignment="Right"/>
                                    <TextBlock Text="BALANCE" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="3" TextAlignment="Right"/>
                                    <TextBlock Text="DUE DATE" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="4"/>
                                    <TextBlock Text="STATUS" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="5"/>
                                    <TextBlock Text="ACTIONS" FontWeight="Bold" Foreground="#555" FontSize="12" Grid.Column="6" TextAlignment="Center"/>
                                </Grid>
                            </Border>

                            <!-- Row 1 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 15, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Amara Okafor" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="FRM-2024-001" FontSize="10" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock Text="$2,500.00" FontSize="12" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="$1,250.00" FontSize="12" Grid.Column="3" TextAlignment="Right" Foreground="#FF9800" VerticalAlignment="Center"/>
                                <TextBlock Text="Jan 15, 2024" FontSize="12" Grid.Column="4" VerticalAlignment="Center"/>
                                <Border Background="#4CAF50" CornerRadius="12" Height="24" Width="70" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Partial" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="⋯" Background="Transparent" BorderThickness="0" FontSize="16" Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"/>
                            </Grid>

                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- Row 2 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 10, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="John Kiplagat" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="FRM-2024-002" FontSize="10" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock Text="$5,000.00" FontSize="12" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="$0.00" FontSize="12" Grid.Column="3" TextAlignment="Right" Foreground="#4CAF50" VerticalAlignment="Center"/>
                                <TextBlock Text="Apr 10, 2024" FontSize="12" Grid.Column="4" VerticalAlignment="Center"/>
                                <Border Background="#4CAF50" CornerRadius="12" Height="24" Width="75" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Fully Paid" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="⋯" Background="Transparent" BorderThickness="0" FontSize="16" Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"/>
                            </Grid>

                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- Row 3 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Oct 5, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Sofia Martinez" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="FRM-2024-003" FontSize="10" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock Text="$3,200.00" FontSize="12" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="$3,200.00" FontSize="12" Grid.Column="3" TextAlignment="Right" Foreground="#D32F2F" VerticalAlignment="Center"/>
                                <TextBlock Text="Jan 5, 2024" FontSize="12" Grid.Column="4" VerticalAlignment="Center"/>
                                <Border Background="#F44336" CornerRadius="12" Height="24" Width="65" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Overdue" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="⋯" Background="Transparent" BorderThickness="0" FontSize="16" Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"/>
                            </Grid>

                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- Row 4 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Sep 28, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Lukas Schmidt" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="FRM-2024-004" FontSize="10" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock Text="$1,800.00" FontSize="12" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="$600.00" FontSize="12" Grid.Column="3" TextAlignment="Right" Foreground="#FF9800" VerticalAlignment="Center"/>
                                <TextBlock Text="Dec 28, 2023" FontSize="12" Grid.Column="4" VerticalAlignment="Center"/>
                                <Border Background="#4CAF50" CornerRadius="12" Height="24" Width="70" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Partial" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="⋯" Background="Transparent" BorderThickness="0" FontSize="16" Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"/>
                            </Grid>

                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- Row 5 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Sep 20, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Maria Gonzales" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="FRM-2024-005" FontSize="10" Foreground="#888"/>
                                </StackPanel>
                                <TextBlock Text="$2,200.00" FontSize="12" Grid.Column="2" TextAlignment="Right" VerticalAlignment="Center"/>
                                <TextBlock Text="$1,100.00" FontSize="12" Grid.Column="3" TextAlignment="Right" Foreground="#FF9800" VerticalAlignment="Center"/>
                                <TextBlock Text="Dec 20, 2023" FontSize="12" Grid.Column="4" VerticalAlignment="Center"/>
                                <Border Background="#4CAF50" CornerRadius="12" Height="24" Width="70" Grid.Column="5" VerticalAlignment="Center" HorizontalAlignment="Left">
                                    <TextBlock Text="Partial" FontSize="10" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                                <Button Content="⋯" Background="Transparent" BorderThickness="0" FontSize="16" Grid.Column="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#999"/>
                            </Grid>

                            <Border Height="1" Background="#F0F0F0" Margin="0,0,0,12"/>

                            <!-- Row 6 -->
                            <Grid Margin="0,0,0,12" Height="50">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="140"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="100"/>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="60"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="Sep 15, 2023" FontSize="12" Grid.Column="0" VerticalAlignment="Center"/>
