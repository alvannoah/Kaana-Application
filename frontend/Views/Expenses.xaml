<Page
    x:Class="Frontend.Views.Expenses"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
        <local:StringToDecimalConverter x:Key="DecimalConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="400">

        <SplitView.Pane>
            <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">

                        <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"/>

                        <TextBox Header="Expense Title / Description"
                                 Text="{Binding FormModel.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="Quantity"
                                Text="{Binding FormModel.Quantity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <DatePicker Header="Date Incurred"
                                    HorizontalAlignment="Stretch"
                                    Date="{Binding FormModel.Date, Mode=TwoWay}"/>

                        <TextBox Header="Total Amount"
                                 InputScope="CurrencyAmount"
                                 Text="{Binding FormModel.Amount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, Converter={StaticResource DecimalConverter}}" />

                        <TextBox Header="Notes / Remarks"
                                 AcceptsReturn="True"
                                 Height="80"
                                 TextWrapping="Wrap"
                                 Text="{Binding FormModel.Notes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="Save Expense"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                Command="{Binding SaveCommand}" />

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Business Expense Management"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Content="+ Record Expense"
                            HorizontalAlignment="Right"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="3.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2.5*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Date" FontWeight="SemiBold"/>
                    <TextBlock Text="Description / Notes" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Quantity" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Amount" Grid.Column="3" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="4" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding Expenses}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:Expense">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="3.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind local:Expenses.FormatShortDate(Date)}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Description}" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind Quantity}" Grid.Column="2" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind Amount}" Grid.Column="3" VerticalAlignment="Center" FontWeight="Bold" Foreground="#F44336"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>