<Page
    x:Class="Frontend.Views.MilkBuyers"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="400">

        <SplitView.Pane>
            <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="14">

                        <TextBlock Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                                   FontSize="18"
                                   FontWeight="Bold"
                                   Foreground="#4CAF50"/>

                        <TextBox Header="Buyer Name"
                                 Text="{Binding FormModel.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBox Header="Contact Person"
                                 Text="{Binding FormModel.ContactPerson, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="Phone Number"
                                 InputScope="TelephoneNumber"
                                 Text="{Binding FormModel.PhoneNumber, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="Email Address"
                                 InputScope="EmailNameOrAddress"
                                 Text="{Binding FormModel.Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <TextBox Header="Address / Location"
                                 Text="{Binding FormModel.Address, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                        <Button Content="Save Buyer"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0"
                                Height="40"
                                Background="#4CAF50"
                                Foreground="White"
                                Command="{Binding SaveCommand}" />

                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Milk Buyers Management"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Content="+ Add New Buyer"
                            HorizontalAlignment="Right"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="2*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Buyer Name" FontWeight="SemiBold"/>
                    <TextBlock Text="Contact Person" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Phone Number" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Location / Address" Grid.Column="3" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="4" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding MilkBuyers}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:MilkBuyer">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="2.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                 </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind ContactPerson}" Grid.Column="1" VerticalAlignment="Center" FontWeight="Medium"/>
                                <TextBlock Text="{x:Bind PhoneNumber}" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Address}" Grid.Column="3" VerticalAlignment="Center" Foreground="Gray"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5" VerticalAlignment="Center">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>