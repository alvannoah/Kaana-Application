<Page
    x:Class="Frontend.Views.FarmerReportPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:dtos="using:Core.DTOs"
    xmlns:local="using:Frontend.Views"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
    </Page.Resources>

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0">
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <TextBlock Text="Period End Settlement Statements" FontSize="24" FontWeight="Bold"/>

                    <Border Background="#FFF3E0" BorderBrush="#FFE0B2" BorderThickness="1" CornerRadius="4" Padding="8,4"
                            Visibility="{Binding IsPeriodClosed, Converter={StaticResource BoolToVisibilityConverter}, ConverterParameter=Invert}">
                        <TextBlock Text="PROVISIONAL / OPEN" FontSize="11" FontWeight="Bold" Foreground="#E65100"/>
                    </Border>

                    <Border Background="#E8F5E9" BorderBrush="#C8E6C9" BorderThickness="1" CornerRadius="4" Padding="8,4"
                            Visibility="{Binding IsPeriodClosed, Converter={StaticResource BoolToVisibilityConverter}}">
                        <TextBlock Text="FINALIZED / SETTLED" FontSize="11" FontWeight="Bold" Foreground="#2E7D32"/>
                    </Border>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Spacing="10">
                    <Button Click="OnPrintClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Print"/>
                            <TextBlock Text="Print Statements"/>
                        </StackPanel>
                    </Button>

                    <Button Style="{StaticResource AccentButtonStyle}" Click="OnExportClick">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <SymbolIcon Symbol="Download"/>
                            <TextBlock Text="Export Excel (CSV)"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="1" Margin="0,6,0,0">
                <TextBlock Text="{Binding PeriodName}" FontSize="14" Foreground="DimGray" FontWeight="Medium"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,24" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="TOTAL LITRES" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalPeriodLitres}" FontSize="22" FontWeight="Bold" Foreground="#1976D2"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="GROSS VALUE" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalPeriodGross}" FontSize="22" FontWeight="Bold"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="DEDUCTIONS" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalPeriodDeductions}" FontSize="22" FontWeight="Bold" Foreground="#D32F2F"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#FFF8E1" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="BALANCE" FontSize="11" Foreground="#B78103"/>
                    <TextBlock Text="{Binding TotalPeriodBalance}" FontSize="22" FontWeight="Bold" Foreground="#F57F17"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="4" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="ADVANCES ISSUED" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalAdvancesIssued}" FontSize="22" FontWeight="Bold" Foreground="#6A1B9A"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="5" Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="ADVANCES RECOVERED" FontSize="11" Foreground="Gray"/>
                    <TextBlock Text="{Binding TotalAdvancesRecovered}" FontSize="22" FontWeight="Bold" Foreground="#00897B"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="6" Background="#E8F5E9" Padding="16" CornerRadius="4">
                <StackPanel>
                    <TextBlock Text="NET PAYABLE" FontSize="11" Foreground="#2E7D32"/>
                    <TextBlock Text="{Binding NetAfterAdvances}" FontSize="22" FontWeight="Bold" Foreground="#1B5E20"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Background="#F2F2F2" Padding="16,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1*"/>
                    <ColumnDefinition Width="3*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="ID" FontWeight="Bold"/>
                <TextBlock Text="Farmer" Grid.Column="1" FontWeight="Bold"/>
                <TextBlock Text="Volume(L)" Grid.Column="2" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Gross" Grid.Column="3" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Deductions" Grid.Column="4" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Advances" Grid.Column="5" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Paid" Grid.Column="6" FontWeight="Bold" HorizontalAlignment="Right"/>
                <TextBlock Text="Balance" Grid.Column="7" FontWeight="Bold" HorizontalAlignment="Right"/>
            </Grid>

            <ListView Grid.Row="1" ItemsSource="{Binding Statements}" SelectionMode="None">
                <ListView.ItemContainerStyle>
                    <Style TargetType="ListViewItem">
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Padding" Value="0"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="dtos:FarmerStatementDto">
                        <Grid Padding="16,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1*"/>
                                <ColumnDefinition Width="3*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                                <ColumnDefinition Width="2*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="{x:Bind FarmerId}" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind FarmerName}" Grid.Column="1" FontWeight="SemiBold" VerticalAlignment="Center"/>

                            <TextBlock Text="{x:Bind TotalLitres}" Grid.Column="2" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind GrossAmount}" Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind TotalDeductions}" Grid.Column="4" HorizontalAlignment="Right" Foreground="Red" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind AdvanceIssued}" Grid.Column="5" HorizontalAlignment="Right" Foreground="#6A1B9A" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind PaidAmount}" Grid.Column="6" HorizontalAlignment="Right" Foreground="#2E7D32" VerticalAlignment="Center"/>
                            <TextBlock Text="{x:Bind Balance}" Grid.Column="7" HorizontalAlignment="Right" FontWeight="Bold" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Grid>
    </Grid>
</Page>