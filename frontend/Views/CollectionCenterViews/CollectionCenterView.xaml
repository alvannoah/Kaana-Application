<Page
    x:Class="Frontend.Views.CollectionCenterViews.CollectionCenterView"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:Core.Models"
    xmlns:local="using:Frontend.Views" 
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <local:BoolToTitleConverter x:Key="BoolToTitleConverter"/>
    </Page.Resources>

    <SplitView
        IsPaneOpen="{Binding IsPaneOpen, Mode=TwoWay}"
        DisplayMode="Overlay"
        PanePlacement="Right"
        OpenPaneLength="400">

        <SplitView.Pane>
            <Grid Background="{ThemeResource SystemControlPageBackgroundChromeLowBrush}" Padding="20">
                <StackPanel Spacing="12">

                    <TextBlock
                        Text="{Binding IsEditMode, Converter={StaticResource BoolToTitleConverter}}"
                        FontSize="18"
                        FontWeight="Bold"/>

                    <TextBox Header="Name"
                             Text="{Binding FormModel.Name, Mode=TwoWay}" />

                    <TextBox Header="Location"
                             Text="{Binding FormModel.Location, Mode=TwoWay}" />

                    <TextBox Header="Manager"
                             Text="{Binding FormModel.ManagerName, Mode=TwoWay}" />

                    <TextBox Header="Phone Number"
                             Text="{Binding FormModel.PhoneNumber, Mode=TwoWay}" />

                    <Button Content="Save"
                            HorizontalAlignment="Stretch"
                            Height="40"
                            Background="#4CAF50"
                            Foreground="White"
                            Command="{Binding SaveCommand}" />

                </StackPanel>
            </Grid>
        </SplitView.Pane>

        <SplitView.Content>
            <StackPanel Padding="20" Spacing="10">

                <Grid Margin="0,0,0,10">
                    <TextBlock Text="Collection Centers"
                               FontSize="22"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>

                    <Button Content="+ Add New"
                            HorizontalAlignment="Right"
                            Background="#2196F3"
                            Foreground="White"
                            Command="{Binding OpenAddCommand}" />
                </Grid>

                <Grid Background="#F5F5F5" Padding="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Name" FontWeight="SemiBold"/>
                    <TextBlock Text="Location" Grid.Column="1" FontWeight="SemiBold"/>
                    <TextBlock Text="Manager" Grid.Column="2" FontWeight="SemiBold"/>
                    <TextBlock Text="Phone Number" Grid.Column="3" FontWeight="SemiBold"/>
                    <TextBlock Text="Actions" Grid.Column="4" FontWeight="SemiBold"/>
                </Grid>

                <ListView ItemsSource="{Binding CollectionCenters}">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="Margin" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListView.ItemContainerStyle>

                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:CollectionCenter">
                            <Grid Padding="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind Location}" Grid.Column="1" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind ManagerName}" Grid.Column="2" VerticalAlignment="Center"/>
                                <TextBlock Text="{x:Bind PhoneNumber}" Grid.Column="3" VerticalAlignment="Center"/>

                                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="5">
                                    <Button Content="Edit"
                                            Background="#FFC107"
                                            Foreground="Black"
                                            Command="{Binding DataContext.OpenEditCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />

                                    <Button Content="Delete"
                                            Background="#F44336"
                                            Foreground="White"
                                            Command="{Binding DataContext.DeleteCommand, ElementName=RootPage}"
                                            CommandParameter="{x:Bind}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

            </StackPanel>
        </SplitView.Content>
    </SplitView>
</Page>